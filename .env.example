# ioBroker simple-api connection
IOBROKER_HOST=localhost
IOBROKER_PORT=8087
IOBROKER_USE_AUTH=false
IOBROKER_USER=admin
IOBROKER_PASSWORD=

# MCP Server
PORT=3000

# OAuth 2.0 Client Credentials (required — server won't start without these)
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_JWT_SECRET=change-me-random-secret-min-32-chars
OAUTH_TOKEN_EXPIRY=3600
